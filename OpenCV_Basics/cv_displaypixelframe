# 1) Display Window CodeThis code creates a solid black window, displays it on your screen, and waits for you to press the 'q' key to close it.
import cv2
import numpy as np

# Create a black image: 600 rows (height), 800 columns (width), 3 color channels (BGR)
window_image = np.zeros((600, 800, 3), dtype=np.uint8)

# Main Loop
while True:
    # Display the image in a window named "OpenCV Window"
    cv2.imshow("OpenCV Window", window_image)
    
    # Wait for 1 millisecond and check if 'q' key is pressed
    if cv2.waitKey(1) & 0xFF == ord('q'):
        break

# Clean up and close all windows
cv2.destroyAllWindows()
