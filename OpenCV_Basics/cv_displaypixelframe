# 2) Pixel/Frame ExperimentsOpenCV uses NumPy arrays for images. 
# Coordinates are formatted as image[y, x] (Row, Column) and the color order is BGR (Blue, Green, Red).

# A. Single Pixel ManipulationModify specific pixels directly 
# using their grid coordinates.
import cv2
import numpy as np

# Create a 400x400 black image
img = np.zeros((400, 400, 3), dtype=np.uint8)

# Change a single pixel at center (y=200, x=200) to Pure Red (B=0, G=0, R=255)
img[200, 200] = [0, 0, 255]

# Change a 50x50 block of pixels to Bright Green
img[100:150, 100:150] = [0, 255, 0]

cv2.imshow("Pixel Experiment", img)
cv2.waitKey(0) # Wait indefinitely for any key press
cv2.destroyAllWindows()
