#B. Live Frame Manipulation (Webcam)Capture live frames from your webcam, 
# manipulate the pixels of every frame in real-time, and show the result.
import cv2

# Open default webcam (0)
cap = cv2.VideoCapture(0)

while True:
    # Capture frame-by-frame
    ret, frame = cap.read()
    if not ret:
        break

    # Experiment 1: Invert the colors of the frame
    inverted_frame = 255 - frame

    # Experiment 2: Draw a blue rectangle on the live frame
    # Syntax: cv2.rectangle(img, start_point, end_point, color_bgr, thickness)
    cv2.rectangle(frame, (100, 100), (300, 300), (255, 0, 0), 3)

    # Display the live results
    cv2.imshow("Live Video (Original + Rect)", frame)
    cv2.imshow("Live Video (Inverted)", inverted_frame)

    # Press 'q' to exit
    if cv2.waitKey(1) & 0xFF == ord('q'):
        break

# Release the camera hardware and close windows
cap.release()
cv2.destroyAllWindows()